---
// FeatureList.astro - High-density feature checklist
export interface Props {
  features: { label: string; description?: string }[];
  class?: string;
}

const { features, class: extraClass = "" } = Astro.props;
---
<div class={`feature-list ${extraClass}`}>
  <ul class="feature-items">
    {features.map((f) => (
      <li class="feature-item">
        <span class="feature-check" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </span>
        <div>
          <strong class="feature-label">{f.label}</strong>
          {f.description && (
            <span class="feature-desc">: {f.description}</span>
          )}
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  .feature-list {
    background: var(--color-surface);
    border: var(--border-hairline);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    box-shadow: var(--shadow-block);
  }

  .feature-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-body-md);
    line-height: var(--leading-body-sm);
    color: var(--color-text);
  }

  .feature-check {
    color: var(--color-success);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .feature-label {
    font-weight: 600;
    color: var(--color-text);
  }

  .feature-desc {
    color: var(--color-text-secondary);
  }
</style>
