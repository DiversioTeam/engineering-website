---
// Footer.astro - Site footer
import { siteConfig } from "../../site.config.mjs";
import BrandLockup from "./BrandLockup.astro";
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <BrandLockup
        href="https://www.diversio.com"
        ariaLabel="Diversio.com"
        target="_blank"
        rel="noopener"
        compact={true}
      />
    </div>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href={siteConfig.githubUrl} target="_blank" rel="noopener">GitHub</a>
      <a href={siteConfig.routes.howWeWork}>How We Work</a>
      <a href={siteConfig.routes.systems}>Systems</a>
      <a href={siteConfig.routes.tools}>{siteConfig.toolsSectionName}</a>
      <a href={siteConfig.routes.blog}>{siteConfig.blogSectionName}</a>
      <a href={siteConfig.routes.community}>Contribute</a>
      <a href={siteConfig.routes.security}>Security</a>
      <a href={siteConfig.routes.terms}>Terms</a>
    </nav>
    <div class="footer-copy">
      Built by <a href="https://www.diversio.com" target="_blank" rel="noopener">Diversio.com</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface);
    border-top: var(--border-hairline);
    padding: var(--space-md) 0;
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-margin);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
  }

  .footer-links {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
  }

  .footer-copy a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-copy a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 960px) {
    .footer-inner {
      justify-content: center;
      padding: 0 var(--space-md);
    }

    .footer-links {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, max-content));
      justify-content: center;
      gap: var(--space-sm) var(--space-lg);
      text-align: center;
    }

    .footer-copy {
      text-align: center;
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
      gap: var(--space-sm);
    }

    .footer-brand {
      align-items: center;
    }

    .footer-links {
      grid-template-columns: 1fr;
      width: 100%;
    }
  }
</style>
