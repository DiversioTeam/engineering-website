---
// Header.astro - Top navigation bar
import { siteConfig } from "../../site.config.mjs";

export interface Props {
  currentNav?: "home" | "howWeWork" | "systems" | "tools" | "blog" | "community";
}

const { currentNav = "home" } = Astro.props;
const navItems = siteConfig.navItems;
---
<header class="header">
  <div class="header-inner">
    <a href={siteConfig.routes.home} class="header-brand" aria-label={`${siteConfig.siteName} Home`}>
      <img
        src="/diversio-logo.svg"
        alt="Diversio"
        class="header-brand-logo"
        width="116"
        height="20"
      />
    </a>
    <div class="header-right-cluster">
      <nav class="header-nav" aria-label="Main navigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`header-nav-link${item.key === currentNav ? " header-nav-link--active" : ""}`}
            aria-current={item.key === currentNav ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <div class="header-right">
        <a href={siteConfig.githubUrl} class="header-icon-btn" aria-label="DiversioTeam on GitHub" target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-surface);
    border-bottom: var(--border-hairline);
    height: var(--header-height);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: 0 var(--space-margin);
    position: relative;
  }

  .header-right-cluster {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-md);
    min-width: 0;
    flex: 1;
    flex-wrap: nowrap;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .header-brand-logo {
    display: block;
    width: auto;
    height: 1.125rem;
    flex-shrink: 0;
  }


  .header-nav {
    display: flex;
    align-items: stretch;
    height: 100%;
    gap: var(--space-md);
    min-width: 0;
  }

  .header-nav-link {
    display: flex;
    align-items: center;
    padding: 0 var(--space-xs);
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    height: 100%;
  }

  .header-nav-link:hover {
    color: var(--color-primary);
  }

  .header-nav-link--active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .header-icon-btn:hover {
    color: var(--color-primary);
    background: var(--color-surface-low);
  }

  /* Mobile */
  @media (max-width: 1120px) {
    .header-inner {
      padding: 0 var(--space-lg);
    }

    .header-right-cluster {
      gap: var(--space-sm);
    }

    .header-nav {
      gap: var(--space-sm);
      flex: 1;
      justify-content: flex-end;
    }

    .header-nav-link {
      font-size: var(--text-body-sm);
      padding: 0 0.35rem;
    }
  }

  @media (max-width: 980px) {
    .header-right-cluster {
      width: 100%;
      order: 3;
      flex-basis: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-xs);
      padding-bottom: var(--space-xs);
    }

    .header-right {
      position: absolute;
      top: var(--space-xs);
      right: var(--space-md);
      height: calc(var(--header-height) - var(--space-xs));
    }

    .header-nav {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-xs);
      height: auto;
      width: 100%;
      padding-bottom: var(--space-xs);
      justify-content: stretch;
    }

    .header-nav-link {
      justify-content: center;
      min-height: 2.5rem;
      padding: 0.55rem 0.75rem;
      white-space: normal;
      text-align: center;
      border: var(--border-hairline);
      border-radius: var(--radius-md);
      background: var(--color-surface-low);
    }

    .header-nav-link--active {
      border-bottom-color: var(--color-primary);
      border-color: var(--color-primary);
      background: var(--color-primary-container);
    }
  }

  @media (max-width: 680px) {
    .header-nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .header {
      height: auto;
    }

    .header-inner {
      padding: 0 var(--space-md);
      flex-wrap: wrap;
      align-items: center;
      row-gap: var(--space-xs);
      padding-top: var(--space-xs);
    }

    .header-brand {
      min-height: calc(var(--header-height) - var(--space-xs));
      flex: 1 1 auto;
    }

    .header-right-cluster {
      gap: var(--space-xs);
    }
  }

  @media (max-width: 480px) {
    .header-nav {
      grid-template-columns: 1fr;
    }
  }

</style>
