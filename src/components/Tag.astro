---
// Tag.astro - Status chip / tag
export interface Props {
  variant?: "default" | "stable" | "beta" | "primary";
  class?: string;
}

const { variant = "default", class: extraClass = "" } = Astro.props;
---
<span class={`tag tag-${variant} ${extraClass}`}>
  <slot />
</span>

<style is:global>
  .tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-code);
    font-size: var(--text-code-sm);
    font-weight: var(--weight-regular);
    line-height: 1;
    padding: var(--space-2xs) var(--space-xs);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tag-default {
    background: var(--color-surface-high);
    color: var(--color-text-secondary);
    border: var(--border-hairline);
  }

  .tag-stable {
    background: var(--color-primary-container);
    color: var(--color-on-primary-container);
    border: 1px solid rgba(91, 52, 233, 0.2);
  }

  .tag-beta {
    background: var(--color-accent-container);
    color: var(--color-accent);
    border: 1px solid rgba(116, 91, 0, 0.3);
  }

  .tag-primary {
    background: var(--color-primary);
    color: #ffffff;
  }
</style>
