---
// Published and scheduled blog article route.
//
// Why this page exists:
// - original posts and curated reposts share one article layout
// - scheduled posts need a stable public URL before they are fully live
// - page-level metadata (canonical URL, social fields, generated OG image) still
//   belongs at the route layer even though the article chrome is shared
//
// Mental model:
// - this file decides *which post* is being shown and what the page metadata is
// - `BlogPostArticle.astro` decides *how the article page is rendered*
import { getCollection, render } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import BlogPostArticle from "../../components/BlogPostArticle.astro";
import { formatEditorialDate } from "../../utils/format-date";
import { getGeneratedOgImage } from "../../utils/og-image";
import { getPublishedBlogPosts, isScheduledBlogPost } from "../../utils/blog-posts";

export async function getStaticPaths() {
  // Include all non-draft posts here, including scheduled ones.
  //
  // Why?
  // - scheduled posts need a stable public URL before they are fully published
  // - that URL can show a restricted preview until the viewer reaches the publish date
  // - published list surfaces still filter these out through getPublishedBlogPosts()
  const posts = (await getCollection("blog")).filter((post) => !post.data.draft);

  return posts.map((post) => ({
    params: { slug: (post.data.slug ?? post.id).replace(/\.md$/, "") },
    props: { post },
  }));
}

const allPosts = await getPublishedBlogPosts();
const { post } = Astro.props;
const { Content, headings } = await render(post);
const isRepost = post.data.sourceType === "repost";
const isScheduledAtBuild = isScheduledBlogPost(post);
const publishedKindLabel = isRepost ? "Curated repost" : "Original post";
const scheduledDateLabel = formatEditorialDate(post.data.publishDate, "long");
const scheduledDateParts = {
  year: post.data.publishDate.getUTCFullYear(),
  month: post.data.publishDate.getUTCMonth() + 1,
  day: post.data.publishDate.getUTCDate(),
};
const postOgSlug = (post.data.slug ?? post.id).replace(/\.md$/, "").replace(/\//g, "-");
const topLevelHeadings = headings.filter((heading) => heading.depth === 2);
const tocHeadings = topLevelHeadings.length >= 2 ? topLevelHeadings : headings.filter((heading) => heading.depth <= 3);
const hasToc = tocHeadings.length >= 2;
const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(words / 225));
const primaryTags = new Set(post.data.tags);
const relatedPosts = allPosts
  .filter((candidate) => candidate.id !== post.id)
  .map((candidate) => {
    const sharedTags = candidate.data.tags.filter((tag) => primaryTags.has(tag)).length;
    const sameAuthor = candidate.data.author.name === post.data.author.name ? 1 : 0;
    const sameType = candidate.data.sourceType === post.data.sourceType ? 1 : 0;
    return {
      candidate,
      score: sharedTags * 10 + sameAuthor * 3 + sameType,
    };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || b.candidate.data.publishDate.getTime() - a.candidate.data.publishDate.getTime())
  .slice(0, 3)
  .map((item) => item.candidate);

const generatedOgImage = getGeneratedOgImage(`/og/blog-${postOgSlug}.png`, "/og/blog-default.png");
const ogImage = post.data.socialImage ?? post.data.heroImage ?? generatedOgImage;
const visibleHeroImage = post.data.heroImage;
---

<PageLayout
  title={post.data.title}
  description={post.data.summary}
  ogImage={ogImage}
  canonicalUrl={post.data.canonicalUrl}
  socialTitle={post.data.socialTitle ?? post.data.title}
  socialDescription={post.data.socialDescription ?? post.data.summary}
  socialType="article"
  currentNav="blog"
>
  <BlogPostArticle
    post={post}
    hasToc={hasToc}
    tocHeadings={tocHeadings}
    readingMinutes={readingMinutes}
    relatedPosts={relatedPosts}
    visibleHeroImage={visibleHeroImage}
    kindLabel={isScheduledAtBuild ? "Scheduled preview" : publishedKindLabel}
    kindClassName={isScheduledAtBuild ? "post-kind--scheduled" : isRepost ? "post-kind--repost" : ""}
    showKindPill={true}
    bannerLabel={isScheduledAtBuild ? "Scheduled preview" : undefined}
    bannerCopy={isScheduledAtBuild ? `This post is scheduled for ${scheduledDateLabel}.` : undefined}
    relatedTitle="More from the engineering blog"
    isScheduledAtBuild={isScheduledAtBuild}
    scheduledDateLabel={scheduledDateLabel}
    scheduledDateParts={scheduledDateParts}
  >
    <Content />
  </BlogPostArticle>
</PageLayout>
